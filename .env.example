# ============================================================================
#  Nestara AI Assistant — environment configuration
#  Copy this file to ".env" and fill in at least one provider key.
#      cp .env.example .env
# ============================================================================

# --- LLM provider ------------------------------------------------------------
# auto | anthropic | openai
# "auto" selects whichever provider below has a key set (Anthropic preferred).
LLM_PROVIDER=auto

# Set the key for the provider you want to use. You only need one.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Models (sensible defaults shown — override only if you need to).
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o

# --- Using Groq (free, OpenAI-compatible) ------------------------------------
# Groq serves open-weight models through an OpenAI-compatible API, so it reuses
# the OpenAI adapter. To use it instead of OpenAI:
#   LLM_PROVIDER=openai
#   OPENAI_API_KEY=gsk_your-groq-key
#   OPENAI_MODEL=llama-3.3-70b-versatile
#   OPENAI_BASE_URL=https://api.groq.com/openai/v1
# Leave OPENAI_BASE_URL blank to talk to real OpenAI.
OPENAI_BASE_URL=

# --- Agent loop --------------------------------------------------------------
# Max tool-call rounds per user turn (guards against runaway loops).
MAX_AGENT_STEPS=6
# Max tokens per LLM completion.
MAX_TOKENS=1024

# --- Authentication policy ---------------------------------------------------
# recognition : a client identified by their registered mobile number is
#               trusted immediately (matches the assignment brief).
# strict      : even recognised clients must pass an OTP before any account
#               data is released (production-grade — flip this on for a real
#               deployment).
AUTH_POLICY=recognition

# --- OTP (mocked — no real SMS is ever sent) ---------------------------------
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=3
# When true, the mock OTP is echoed back in the tool result + server console so
# a presenter can verify without an SMS gateway. Set to false to simulate a
# real flow where the code only appears in the (mock) "SMS" log.
OTP_DEV_ECHO=true

# --- Misc --------------------------------------------------------------------
LOG_DIR=logs
